<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>INDIAN BLANKOS</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">

<style>
body{font-family:'Poppins';background:#0b1220;color:white;}

.hero{
height:80vh;
display:flex;
flex-direction:column;
justify-content:center;
align-items:center;
}

.hero h1{font-size:60px;color:#3b82f6;}

.card{background:#111827;border-radius:5px;}
.card img{height:250px;object-fit:cover;}
</style>
</head>

<body>

<div class="hero">
<h1>INDIAN BLANKOS</h1>
<p class="text-secondary">Directors spark of thought to crafting reality</p>

<div class="input-group w-50 mt-4">
<input id="search" class="form-control" placeholder="Search...">
<button class="btn btn-primary" onclick="search()">Search</button>
<button class="btn btn-danger" onclick="clearAll()">Clear</button>
</div>

<div id="suggestions" class="bg-dark w-50 mt-2"></div>
</div>

<div class="container">
<div id="results" class="row g-3"></div>
</div>

<script>

const input = document.getElementById("search");
const sug = document.getElementById("suggestions");
const res = document.getElementById("results");

/* SUGGEST */
input.addEventListener("input", async ()=>{
let val=input.value;
if(!val){sug.innerHTML="";return;}

let data = await fetch(`/search?q=${val}`);
let results = await data.json();

sug.innerHTML="";
results.slice(0,5).forEach(d=>{
let div=document.createElement("div");
div.className="p-2 border-bottom";
div.innerText=d.name;
div.onclick=()=>{
input.value=d.name;
search();
};
sug.appendChild(div);
});
});

/* SEARCH */
async function search(){
let val=input.value;
let data=await fetch(`/search?q=${val}`);
let results=await data.json();

res.innerHTML="";

results.forEach(d=>{
res.innerHTML+=`<h4 class="text-primary mt-4">${d.name}</h4>`;

d.movies.forEach(m=>{
res.innerHTML+=`
<div class="col-md-3">
<div class="card">
<img src="${m.poster}">
<div class="p-2">${m.title}</div>
</div>
</div>`;
});
});
}

/* CLEAR */
function clearAll(){
input.value="";
sug.innerHTML="";
res.innerHTML="";
}

</script>

</body>
</html>
